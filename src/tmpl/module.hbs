{{!--
  module.hbs - Page template for module doclets.

  Overrides the "primary" block to show the module's description and any
  classdesc from exported members, plus the @requires and @details tags.
  The secondary block (symbol sections) is inherited from site/layout.
--}}
{{#extend "site/layout"}}

	{{#content "primary"}}
		<dl class="symbol">
			<dt class="symbol-title {{kind}}"></dt>
			<dd class="symbol-details {{kind}}">
				<div class="symbol-details-inner">
					{{> tag/description doclet}}
					{{#each doclet.modules}}
						{{#if classdesc}}
							{{> tag/description this}}
						{{/if}}
					{{/each}}
					{{> tag/requires doclet}}
					{{> tag/details doclet options=options}}
				</div>
			</dd>
		</dl>
	{{/content}}

{{/extend}}