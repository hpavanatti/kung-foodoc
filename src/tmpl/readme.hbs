{{!--
  readme.hbs - Landing page template (index.html).

  Overrides the entire "content" block to render the README.md markdown
  without the primary/secondary symbol structure. The contents are
  pre-parsed by JSDoc's markdown processor.
--}}
{{#extend "site/layout"}}

	{{#content "content"}}
		<section class="readme-section">
			<article>{{{doclet.contents}}}</article>
		</section>
	{{/content}}

{{/extend}}