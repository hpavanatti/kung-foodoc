{{!--
  list.hbs - Index page for a kind (Classes, Modules, Tutorials, etc.).

  Overrides "primary" to show just the title, and "secondary" to list
  all members of that kind using the symbol helper with list=true mode.
  Created by postProcessor.registerLists() for each navMember kind.
--}}
{{#extend "site/layout"}}
	{{#content "primary"}}
		<h2>{{{doclet.primaryTitleHTML}}}</h2>
	{{/content}}
	{{#content "secondary"}}
		<article class="secondary">
			{{#if doclet.members}}
				<dl class="symbol">
					{{#each doclet.members}}
						{{#unless @first}}<hr/>{{/unless}}
						{{symbol this list=true options=../options}}
					{{/each}}
				</dl>
			{{/if}}
		</article>
	{{/content}}
{{/extend}}