{{#if returns}}
	{{#callout "Returns" "callout-success"}}
		<form class="details-form returns">
			{{#each returns}}
				<div class="row mb-2">
					<label class="col-sm-3 col-form-label returns-type">{{type-names type}}</label>
					<div class="col-sm-9">
						<div class="form-control-plaintext returns-description">{{{description}}}</div>
					</div>
				</div>
			{{/each}}
		</form>
	{{/callout}}
{{/if}}