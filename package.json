{
  "name": "kung-foodoc",
  "version": "0.2.0",
  "description": "A Bootstrap 5 and Handlebars based JSDoc 4 template.",
  "license": "GPL-3.0",
  "author": "hpavanatti",
  "contributors": [
    "Steve Usher",
    "Henrique Pavanatti"
  ],
  "homepage": "https://github.com/hpavanatti/kung-foodoc#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hpavanatti/kung-foodoc.git"
  },
  "bugs": {
    "url": "https://github.com/hpavanatti/kung-foodoc/issues"
  },
  "keywords": [
    "jsdoc",
    "jsdoc-template",
    "bootstrap",
    "handlebars",
    "documentation"
  ],
  "main": "./template/publish.js",
  "files": [
    "template/",
    "README.md"
  ],
  "scripts": {
    "build": "grunt template",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "examples": "grunt all",
    "examples:default": "grunt default",
    "examples:inline": "grunt inline",
    "examples:logo-color": "grunt logo-color",
    "examples:collapse": "grunt collapse",
    "examples:namespaced": "grunt namespaced"
  },
  "dependencies": {
    "cheerio": "1.2.0",
    "dayjs": "1.11.20",
    "glob": "13.0.6",
    "grunt": "1.6.1",
    "grunt-contrib-clean": "2.0.1",
    "grunt-contrib-copy": "1.0.0",
    "grunt-contrib-cssmin": "5.0.0",
    "grunt-contrib-uglify": "5.2.2",
    "handlebars": "4.7.9",
    "handlebars-layouts": "3.1.4",
    "jsdoc": "4.0.5",
    "lunr": "2.3.9",
    "sanitize-html": "2.17.2"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@babel/preset-env": "7.29.2",
    "bootstrap": "5.3.8",
    "clipboard": "2.0.11",
    "eslint": "9.39.4",
    "eslint-plugin-import-x": "4.16.2",
    "grunt-contrib-handlebars": "3.0.0",
    "jquery": "4.0.0",
    "neostandard": "0.13.0",
    "prismjs": "1.30.0"
  }
}